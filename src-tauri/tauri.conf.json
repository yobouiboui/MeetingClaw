{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MeetingClaw",
  "version": "0.1.0",
  "identifier": "com.meetingclaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeetingClaw",
        "width": 1520,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "MeetingClaw",
    "homepage": "https://github.com/yobouiboui/MeetingClaw",
    "category": "Productivity",
    "shortDescription": "Windows desktop meeting copilot with live transcript, OCR and AI suggestions.",
    "longDescription": "MeetingClaw is a Windows-first desktop meeting copilot built with Tauri, React and Rust. It captures live meeting context from microphone and screen sharing, generates transcript-aware suggestions, maintains notes and follow-up drafts, and stores meeting history locally.",
    "copyright": "Copyright 2026 MeetingClaw contributors",
    "license": "MIT",
    "targets": "nsis",
    "useLocalToolsDir": true,
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "French"
        ],
        "compression": "lzma",
        "displayLanguageSelector": false,
        "startMenuFolder": "MeetingClaw",
        "minimumWebview2Version": "120.0.0.0"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
