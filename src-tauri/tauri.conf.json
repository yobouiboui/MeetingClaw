{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MeetingClaw",
  "version": "0.1.0",
  "identifier": "com.meetingclaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeetingClaw",
        "width": 1520,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
